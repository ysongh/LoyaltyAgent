# --- Agent service ----------------------------------------------------------
# Copy to server/.env and fill in. NEVER commit the real .env.

# Telegram bot token from @BotFather (https://t.me/BotFather). SECRET.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Dynamic server-wallet credentials (Dashboard > Developers).
DYNAMIC_ENVIRONMENT_ID=your_dynamic_environment_id
DYNAMIC_AUTH_TOKEN=your_dynamic_server_api_token

# Supabase (backend uses the SERVICE ROLE key — bypasses RLS; never expose client-side).
SUPABASE_URL=https://xxihgjberaerorhlssps.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Arc chain id — used as the EIP-712 domain chainId for receipt verification.
ARC_CHAIN_ID=5042002

# Anthropic API key for the Stage 3 intent parser (claude-sonnet-4-6). SECRET.
ANTHROPIC_API_KEY=sk-ant-your_api_key

# --- Stage 4: on-chain execution ---------------------------------------------
# Arc RPC for reads/writes (defaults to the public endpoint if unset).
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
# Deployed contract addresses on Arc.
LOYALTY_POINTS_ADDRESS=0xyour_loyaltypoints_address
MERCHANT_ESCROW_ADDRESS=0xyour_merchantescrow_address
# Single-merchant demo: pin all on-chain actions to this merchant id.
DEMO_MERCHANT_ID=1
# Contract owner key (RELAYER EOA) — bootstrap only (registerMerchant). SECRET.
RELAYER_PRIVATE_KEY=0xyour_relayer_private_key

# --- Seed script only (pnpm seed) -------------------------------------------
# Merchant test signer private key (0x-prefixed). Signs receipt payloads; its
# address is stored as the merchant's registered signer. SECRET.
MERCHANT_TEST_PRIVATE_KEY=0xyour_merchant_test_private_key
# Optional seed overrides:
# MERCHANT_TEST_ID=1
# POINTS=100
