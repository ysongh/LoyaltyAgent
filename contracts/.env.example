# Arc Testnet RPC endpoint
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Deployer / relayer account private key (include the 0x prefix).
# NEVER commit the real value — this file is a template only.
#
# Arc uses USDC as its native gas token, so this account pays gas in USDC (not ETH).
# Fund it with testnet USDC from https://faucet.circle.com BEFORE running any
# connection/deploy script, or the balance read will show zero.
RELAYER_PRIVATE_KEY=0xyour_private_key_here

# The MerchantEscrow funds and pays out in Arc's NATIVE USDC (the gas token),
# so no separate USDC token address is needed.

# Optional: ERC-1155 metadata URI for LoyaltyPoints ({id} is substituted per token).
# TOKEN_URI=https://loyalty.example/metadata/{id}.json

# Optional: platform owner of LoyaltyPoints (defaults to the deployer address).
# LOYALTY_OWNER=0xyour_platform_owner_address_here
